{
  "name": "auto-dev",
  "version": "0.1.0",
  "description": "Claude Code SDK 기반 개발 자동화 에이전트",
  "type": "module",
  "bin": { "auto-dev": "dist/cli.js" },
  "scripts": {
    "dev":        "tsx src/cli.ts",
    "build":      "tsc",
    "start":      "node dist/cli.js",
    "scaffold":   "tsx src/cli.ts scaffold",
    "review":     "tsx src/cli.ts review",
    "test-agent": "tsx src/cli.ts test",
    "cicd":       "tsx src/cli.ts cicd",
    "spec":       "tsx src/cli.ts spec",
    "status":     "tsx src/cli.ts status",
    "serve":      "tsx src/cli.ts serve"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^9.6.0",
    "commander": "^12.1.0",
    "hono": "^4.6.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
