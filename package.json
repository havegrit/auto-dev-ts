{
  "name": "auto-dev",
  "version": "0.1.0",
  "description": "Claude Code SDK 기반 개발 자동화 에이전트",
  "type": "module",
  "bin": {
    "auto-dev": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc && cp src/store/schema.sql dist/store/schema.sql",
    "start": "node dist/cli.js",
    "scaffold": "tsx src/cli.ts scaffold",
    "review": "tsx src/cli.ts review",
    "test-agent": "tsx src/cli.ts test",
    "cicd": "tsx src/cli.ts cicd",
    "spec": "tsx src/cli.ts spec",
    "status": "tsx src/cli.ts status",
    "serve": "tsx src/cli.ts serve",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.162",
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^12.1.0",
    "hono": "^4.6.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.4",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=24"
  }
}
