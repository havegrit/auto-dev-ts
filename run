#!/usr/bin/env bash
set -euo pipefail
if [ "$(id -u)" -ne 0 ] && [[ "${HOME:-}" == /root* ]]; then
  home="$(getent passwd "$(id -un)" | cut -d: -f6)"
  if [ -n "$home" ] && [ "$home" != "/root" ]; then
    export HOME="$home"
    if [[ "${CODEX_HOME:-}" == /root* ]]; then
      export CODEX_HOME="$HOME/.codex"
    fi
  fi
fi
exec npx tsx src/cli.ts "$@"
