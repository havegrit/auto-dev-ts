# 에이전트 파일 I/O 작업 디렉토리
AUTO_DEV_WORKSPACE_ROOT=./data/workspace

# SQLite DB 경로
AUTO_DEV_DB_PATH=./data/auto-dev.db

# HTTP 서버 바인드 (WSL2에서 Windows 브라우저 접근 시 0.0.0.0 사용)
AUTO_DEV_BIND_ADDR=127.0.0.1
AUTO_DEV_BIND_PORT=8080

# 사용할 Claude 모델 (기본: claude-sonnet-4-6)
# AUTO_DEV_MODEL=claude-sonnet-4-6

# Effort 레벨: low | medium | high | xhigh | max (기본: high)
# AUTO_DEV_EFFORT=high

# 일일 실행 횟수 제한 (런어웨이 방지)
AUTO_DEV_DAILY_RUN_LIMIT=100

# rate limit 감지 회로 차단기 — resetsAt 미제공 플랫폼의 fallback 쿨다운 (ms, 기본 5분)
# AUTO_DEV_CIRCUIT_BREAKER_FALLBACK_MS=300000

# issue-tracker 연동 (선택 — 설정 시 브리핑 + 자동 처리 활성화)
# AUTO_DEV_ISSUE_TRACKER_URL=http://127.0.0.1:8081
# AUTO_DEV_ISSUE_TRACKER_STATUS=OPEN

# 워크로그 브리핑 스케줄러
# AUTO_DEV_WORKLOG_BRIEFING_ENABLED=false
# AUTO_DEV_WORKLOG_BRIEFING_CRON=0 9 * * *
# AUTO_DEV_WORKLOG_PATH=./data/worklog.md
